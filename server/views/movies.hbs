{{> header}}
{{> menu}}

<main>
    <h1>Llistat de Pel·lícules</h1>
    
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Títol</th>
                    <th>Any</th>
                    <th>Classificació</th> <th>Actors principals</th> <th>Accions</th>
                </tr>
            </thead>
            <tbody>
                {{#each movies}}
                <tr>
                    <td>
                        <strong>{{this.title}}</strong><br>
                        <small>{{this.description}}</small> </td>
                    <td>{{this.release_year}}</td>
                    <td>{{this.rating}}</td> <td>{{this.actors}}</td> <td><button class="btn-info">Veure detalls</button></td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>

    {{#unless movies}}
        <p>No s'han trobat pel·lícules.</p>
    {{/unless}}
</main>

{{> footer}}